# ─── Clear conflicting defaults ────────────────────────────────────────────────
keymap  h    NULL          # was HELP — moving it to ?
keymap  l    NULL          # was LINE_INFO
keymap  j    NULL          # was MOVE_DOWN (re-binding explicitly)
keymap  k    NULL          # was MOVE_UP
keymap  b    NULL          # was PREV_WORD
keymap  w    NULL          # was NEXT_WORD
keymap  g    NULL          # was GOTO (re-binding to gg/G idiom)
keymap  G    NULL
keymap  d    NULL          # was DOWN_HALF (re-binding)
keymap  u    NULL          # was UP_HALF
keymap  r    NULL          # was RELOAD (re-binding)
keymap  q    NULL          # was QUIT (re-binding)
keymap  /    NULL          # was SEARCH (re-binding)
keymap  n    NULL          # was NEXT_MARK (re-binding)
keymap  N    NULL
keymap  t    NULL          # re-binding to NEW_TAB
keymap  T    NULL

# ─── Core movement (vim hjkl) ──────────────────────────────────────────────────
keymap  j    MOVE_DOWN
keymap  k    MOVE_UP
keymap  h    MOVE_LEFT      # horizontal scroll (useful on wide pages)
keymap  l    MOVE_RIGHT

# ─── Page / half-page scrolling ────────────────────────────────────────────────
#keymap  C-d  DOWN_HALF      # ctrl-d: half page down  (like vim)
#keymap  C-u  UP_HALF      # ctrl-u: half page up
keymap  C-f  NEXT_PAGE      # ctrl-f: full page down
keymap  C-b  PREV_PAGE      # ctrl-b: full page up
keymap  SPC  NEXT_PAGE      # space:  full page down  (classic pager behaviour)

# ─── Document start / end (qutebrowser gg / G) ─────────────────────────────────
keymap  g    BEGIN          # gg: top of page  (single g works; w3m has no chord input)
keymap  G    END            # G:  bottom of page

# ─── Link navigation (qutebrowser hint-style) ──────────────────────────────────
# w3m has no visual hint overlay, but two viable approaches:
#   1. f/F cycle through links sequentially (TAB behaviour, just remapped)
#   2. Type the link number shown in [N] brackets, then RET to follow
# Both are much faster than pure arrow-key navigation.
keymap  f    NEXT_LINK      # f: focus next link (follow with RET or l)
keymap  F    PREV_LINK      # F: focus previous link
keymap  RET  GOTO_LINK    # enter: follow focused link
keymap  M-f  GOTO_LINK    # alt-f: follow in same tab
keymap  M-F  TAB_LINK       # alt-F: follow link in new tab (like qutebrowser F)

# ─── URL entry ─────────────────────────────────────────────────────────────────
keymap  o    GOTO           # o: open URL prompt  (like qutebrowser)
keymap  O    TAB_GOTO       # O: open URL in new tab

# ─── History navigation (qutebrowser H/L) ──────────────────────────────────────
keymap  H    BACK           # H: go back in history
# w3m has no true FORWARD; use history list instead:
keymap  L    HISTORY        # L: open history list (closest to forward)

# ─── Reload ────────────────────────────────────────────────────────────────────
keymap  r    RELOAD         # r: reload page

# ─── Tabs ──────────────────────────────────────────────────────────────────────
keymap  t    NEW_TAB        # t: new tab
keymap  x    CLOSE_TAB      # x: close current tab  (like qutebrowser)
keymap  J    NEXT_TAB       # J: next tab            (like vim gt)
keymap  K    PREV_TAB       # K: previous tab        (like vim gT)
keymap  C-t  TAB_MENU       # ctrl-t: tab list popup

# ─── Search ────────────────────────────────────────────────────────────────────
keymap  /    SEARCH         # /: forward search
keymap  ?    SEARCH_BACK    # ?: backward search
keymap  n    SEARCH_NEXT    # n: next result
keymap  N    SEARCH_PREV    # N: previous result (note: may be ISEARCH_BACK on some builds)

# ─── Yanking (copy to clipboard) ───────────────────────────────────────────────
# Requires xclip or xsel; adjust if using wl-clipboard (wl-copy)
keymap  yy   EXTERN "echo -n $W3M_URL | xclip -selection clipboard"
keymap  yY   EXTERN "echo -n $W3M_CURRENT_URL | xclip -selection clipboard && notify-send 'w3m' 'URL copied'"
keymap  yl   EXTERN_LINK "echo -n %s | xclip -selection clipboard"  # yank hovered link

# ─── Open page in external browsers ────────────────────────────────────────────
# Uses extbrowser / extbrowser2 / extbrowser3 from config
keymap  M-l  EXTERN "$HOME/.config/w3m/open-lynx.sh $W3M_CURRENT_URL"        # alt-l: open current page in lynx
keymap  M-L  EXTERN_LINK "$HOME/.config/w3m/open-lynx.sh %s"                 # alt-L: open focused link in lynx
keymap  M-b  EXTERN "$HOME/.config/w3m/open-browsh.sh $W3M_CURRENT_URL"      # alt-b: open current page in browsh
keymap  M-B  EXTERN_LINK "$HOME/.config/w3m/open-browsh.sh %s"               # alt-B: open current focused link in browsh
keymap  M-x  EXTERN "xdg-open $W3M_CURRENT_URL"                              # alt-x: open in xdg-open (GUI browser)
keymap  M-X  EXTERN_LINK "xdg-open %s"                                       # alt-X: open current focused lin in xdg-open

# ─── Source / info ─────────────────────────────────────────────────────────────
keymap  v    VIEW    # v: view page source (qutebrowser style)
keymap  i    LINE_INFO      # i: show link target / current URL in statusbar
keymap  I    INFO           # I: full page info popup

# ─── Bookmarks ─────────────────────────────────────────────────────────────────
keymap  B    BOOKMARK       # B: open bookmarks
keymap  M-b  ADD_BOOKMARK   # alt-b: add current page to bookmarks (conflicts w/ browsh — pick one)
                            # Recommendation: use ,ab for add-bookmark, keep M-b for browsh

# ─── Downloads ─────────────────────────────────────────────────────────────────
keymap  D    DOWNLOAD       # D: download current page/link

# ─── Menu ──────────────────────────────────────────────────────────────────────
keymap  M-m  MENU           # alt-m: open the custom menu (defined in ~/.w3m/menu)
keymap  M-o  OPTIONS         # alt-o: open settings dialog

# ─── Marks (vim-style) ─────────────────────────────────────────────────────────
keymap  m    MARK           # m: set mark at cursor
keymap  M-n  NEXT_MARK      # alt-n: jump to next mark
keymap  M-N  PREV_MARK      # alt-N: jump to prev mark

# ─── Misc ──────────────────────────────────────────────────────────────────────
keymap  ZZ   QUIT           # ZZ: quit  (vim-style, no confirm)
keymap  q    QUIT           # q: quit
keymap  ZQ   QUIT
keymap  C-l  REDRAW         # ctrl-l: redraw screen  (useful in tmux)
