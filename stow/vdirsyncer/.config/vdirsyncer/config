[general]
# Folder where vdirsyncer can store some metadata about each pair.
status_path = "~/.local/share/vdirsyncer/status/"

# Posteo Contacts
[pair posteo_contacts]
a = "posteo_contacts_local"
b = "posteo_contacts_remote"
collections = ["from a", "from b"]

metadata = ["displayname"]

[storage posteo_contacts_local]
type = "filesystem"
path = "~/.local/contacts/adam.dickison@posteo.net"
fileext = ".vcf"

[storage posteo_contacts_remote]
type = "carddav"
url = "https://posteo.de:8443"
username = "adam.dickison@posteo.net"
password.fetch = ["command", "kp", "get", "mail/posteo.de"]
read_only = true

# Posteo Calendar
[pair posteo_calendars]
a = "posteo_calendar_local"
b = "posteo_calendar_remote"
collections = ["from a", "from b"]
conflict_resolution = "b wins"

[storage posteo_calendar_local]
type = "filesystem"
path = "~/.local/share/calendars/adam.dickison@posteo.net/"
fileext = ".ics"

[storage posteo_calendar_remote]
type = "caldav"
url = "https://posteo.de:8443/calendars/adam.dickison/default/"
username = "adam.dickison@posteo.net"
password.fetch = ["command", "kp", "get", "mail/posteo.de"]

# US Holiday Calendar
[pair holidays]
a = "holidays_local"
b = "holidays_remote"
collections = null

[storage holidays_local]
type = "filesystem"
path = "~/.local/share/calendars/holidays/"
fileext = ".ics"

[storage holidays_remote]
type = "http"
url = "https://ics.calendarlabs.com/76/661933dc/US_Holidays.ics"
