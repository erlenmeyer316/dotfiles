# ~/.config/neomutt/neomuttrc
# Entry point — sources all modules in order

source ~/.config/neomutt/behavior.rc
source ~/.config/neomutt/sidebar.rc
source ~/.config/neomutt/bindings.rc

# Load default account (Posteo)
source ~/.config/neomutt/accounts/posteo.rc

# HTML rendering via w3m
set mailcap_path = ~/.config/neomutt/mailcap
auto_view text/html                              # render HTML automatically
alternative_order text/plain text/enriched text/html
                                                 # prefer plain text, fall back to HTML

# khard address book query
set query_command = "khard email --parsable '%s'"

# Auto-sync all accounts on startup by pushing the sync macro
startup-hook 'push "gs"'
